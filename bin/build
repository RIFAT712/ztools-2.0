#!/usr/bin/env bash
# Exit on error
set -e

echo "---> Starting Custom Build Script"

# 1. Build the Python environment (handled by default buildpack, but we can add steps here)
# pip install -r requirements.txt # (Already done by heroku/python)

# 2. Build the Frontend
if [ -d "frontend" ]; then
    echo "---> Building Frontend"
    cd frontend
    
    # Toolforge buildpacks include Node.js, but we might need to ensure it's available
    # If using heroku-buildpack-multi or if node is in the environment:
    npm install
    npm run build
    
    cd ..
    echo "---> Frontend Build Complete"
else
    echo "---X Error: frontend directory not found"
    exit 1
fi

echo "---> Build Script Finished Successfully"
